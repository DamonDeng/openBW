# SC1 game assets (copyrighted; never commit)
original_resources/

# Local test scratch: API keys, generated user files, etc.
# Contents are secrets and machine-specific; never commit.
test_resources/

# Local dev tools + their extracted output. Contents include
# Blizzard-owned art assets (MPQ dumps); never commit.
project_tools/

# AWS account details, IAM keys, isengard creds, cluster names, and
# any other tenant-specific configuration. Machine- and account-
# specific; contains secrets; never commit.
aws_account_info/

# Build outputs
build/
build_*/
cmake-build-*/
observer_log.txt
log.txt

# Soak-run evidence: raw sync-log dumps + agent stdout, tens of MB
# per run. The insights are captured in commit messages + memory
# notes; the raw dumps stay on disk for local re-analysis only.
docs/soak_qt_20_*/

# Local scratch: stray agent log files from ad-hoc runs.
logs/

# Editor / OS cruft
.DS_Store
.vscode/
.idea/
*.swp

# Python
__pycache__/
*.pyc
