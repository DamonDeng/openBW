---
# StorageClass for EBS gp3 via aws-ebs-csi-driver. Idempotent — safe to
# re-apply. Fargate mounts this via the CSI driver we install alongside.
apiVersion: storage.k8s.io/v1
kind: StorageClass
metadata:
  name: simsc-ebs-gp3
provisioner: ebs.csi.aws.com
volumeBindingMode: Immediate
reclaimPolicy: Retain
parameters:
  type: gp3
  encrypted: "true"
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: simsc-pgdata
  namespace: ${K8S_NAMESPACE}
spec:
  accessModes: [ReadWriteOnce]
  storageClassName: simsc-ebs-gp3
  resources:
    requests:
      storage: 10Gi
