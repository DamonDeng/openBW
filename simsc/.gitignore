# Rendered manifests contain account IDs, ARNs, and pool IDs — never commit.
deploy/*.yaml
!deploy/*.yaml.tmpl

# Python
__pycache__/
*.pyc
.venv/

# WASM observer build products — copied in from wasm/dist at image
# build time. Large (>100 MB .data), architecture-independent, and
# re-generatable from wasm/observer_wasm.cpp. Not committed to git;
# regenerate with wasm/build_observer_wasm.sh + cp into simscapp/.
app/static/simscapp/observer_wasm.data
app/static/simscapp/observer_wasm.wasm
app/static/simscapp/observer_wasm.js
# Same story for the slim (self-contained) variant — 22.7 MB .data,
# regenerate with wasm/build_observer_wasm_slim.sh + cp.
app/static/simscapp/observer_wasm_slim.data
app/static/simscapp/observer_wasm_slim.wasm
app/static/simscapp/observer_wasm_slim.js
